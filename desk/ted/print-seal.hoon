::  send on /spider/garden/json/print-seal/json
::
^-  thread:spider
|=  jon=vase
=/  m  (strand ,vase)
^-  form:m
;<  =bowl:spider  bind:m  get-bowl
?~  jun=!<((unit json) jon)
  (pure:m !>(`json`[%s 'invalid-request']))
=/  pes=pers:gall  (pers:dejs:treaty u.jun)
%-  pure:m
!>  ^-  json
:-  %a
=-  (sort - aor)
%+  turn  ~(tap in pes)
|=(=perm:gall s+(crip <perm>))
